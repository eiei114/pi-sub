{
  "name": "@eiei114/pi-sub-bar",
  "version": "2.0.0",
  "description": "Usage widget extension for pi-coding-agent - shows current provider usage above the editor",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-sub.git",
    "directory": "packages/sub-bar"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "pi": {
    "extensions": [
      "./index.ts",
      "node_modules/@eiei114/pi-sub-core/index.ts",
      "../pi-sub-core/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "test": "tsx test/all.test.ts",
    "test:watch": "tsx watch test/all.test.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@eiei114/pi-sub-core": "^2.0.0",
    "@eiei114/pi-sub-shared": "^2.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.0",
    "@earendil-works/pi-tui": "^0.80.0"
  }
}
